{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "declaration": true,
    "sourceMap": true,

    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": false
  },

  "include": [
    "src/**/*",
    "tests/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}